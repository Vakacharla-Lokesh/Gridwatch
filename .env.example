# GridWatch Environment Configuration

# PostgreSQL Database
POSTGRES_DB=gridwatch
POSTGRES_USER=gridwatch
POSTGRES_PASSWORD=secret
DATABASE_URL=postgresql://gridwatch:secret@postgres:5432/gridwatch

# Server Port
PORT=4000
NODE_ENV=development

# Upstash Redis Client (for session store, Socket.IO adapter, queues)
# Sign up at https://upstash.com
UPSTASH_REDIS_REST_URL=https://your-account.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-secret-token

# JWT Auth
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_EXPIRY=24h

# CORS & Frontend
CORS_ORIGIN=http://localhost:5173
VITE_API_URL=http://localhost:4000
VITE_WS_URL=http://localhost:4000
